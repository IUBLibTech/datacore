<% hide_files = DeepBlueDocs::Application.config.embargo_manage_hide_files %>

<% unless assets_with_deactivated_embargoes.present? %>

  <p class="text-center"><%= t('.missing') %></p>

<% else %>

  <% assets_with_deactivated_embargoes.each do |curation_concern| %>
    <% hrt = curation_concern.human_readable_type %>
    <% next if hide_files && hrt == "File" %>
    <%= link_to curation_concern, edit_embargo_path(curation_concern) %> <%= visibility_badge(curation_concern.visibility) %>
    <%= render partial: 'embargo_history', object: curation_concern.embargo_history %>
  <% end %>

<% end %>
